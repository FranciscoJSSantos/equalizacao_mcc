# Copie este arquivo para .streamlit/secrets.toml e preencha com suas credenciais.
# Nunca commit o secrets.toml real — ele está no .gitignore.
#
# Credenciais OAuth: https://console.cloud.google.com/apis/credentials
# Adicione REDIRECT_URI como "URI de redirecionamento autorizado" no OAuth App.
#
#   Local dev  → http://localhost:8501/
#   Produção   → https://<seu-app>.streamlit.app/

GOOGLE_CLIENT_ID     = "seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-seu-secret"
REDIRECT_URI         = "http://localhost:8501/"
ALLOWED_DOMAIN       = "suzano.com.br"
